        <Param val="if ((! Anskey.keys)) {&amp;#10;    fb_msg = &quot;\u592a\u6162\u4f5c\u7b54\uff01&quot;;&amp;#10;} else {&amp;#10;    if ((Anskey.corr === 1)) {&amp;#10;        fb_msg = &quot;\u6b63\u78ba&quot;;&amp;#10;    } else {&amp;#10;        fb_msg = &quot;\u932f\u8aa4&quot;;&amp;#10;    }&amp;#10;}&amp;#10;Feedback_text.setText(fb_msg);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
